# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./frontline_desk.db

# --- JWT auth ---
JWT_SECRET=change-me-please-32-chars-min-xxxxxxxxxxxxxx
JWT_ALGO=HS256
JWT_ACCESS_TTL_MIN=720
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe!123
SEED_ADMIN_NAME=Branch Admin

# --- Gemini API ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# When true or when keys are empty, ASR/LLM shows demo placeholders
DEMO_MODE=false

# CORS for Vite dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
