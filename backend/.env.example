# --- Database ---
# Default: local SQLite file (zero setup). For Postgres set:
#   DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/frontline_desk
DATABASE_URL=sqlite+aiosqlite:///./frontline_desk.db

# --- JWT auth ---
JWT_SECRET=change-me-please-32-chars-min-xxxxxxxxxxxxxx
JWT_ALGO=HS256
JWT_ACCESS_TTL_MIN=720
# First admin (auto-created on startup if no users exist)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe!123
SEED_ADMIN_NAME=Branch Admin

# --- Bhashini / ULCA — from https://bhashini.gov.in/ ---
BHASHINI_USER_ID=
BHASHINI_ULCA_API_KEY=
# Optional: override pipeline config URL
# BHASHINI_PIPELINE_CONFIG_URL=https://meity-auth.ulcacontrib.org/ulca/apis/v0/model/getModelsPipeline

# --- LLM (swappable) ---
# LLM_PROVIDER: openai | groq | mock
LLM_PROVIDER=groq
# When LLM_PROVIDER=groq, GROQ_API_KEY is used and base_url is set automatically
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# When LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# When true or when Bhashini keys are empty, ASR shows demo placeholders
DEMO_MODE=false

# CORS for Vite dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
